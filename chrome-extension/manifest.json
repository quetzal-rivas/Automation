{
  "manifest_version": 3,
  "name": "Gemini Voice Bridge",
  "version": "1.0",
  "description": "Puente de voz para el Directive Hub conectando con Gemini Live.",
  "permissions": [
    "scripting",
    "activeTab",
    "offscreen",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
